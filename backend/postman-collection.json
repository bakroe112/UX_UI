{
  "info": {
    "name": "Job Recruitment API",
    "description": "API collection for Job Recruitment Application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"candidate@example.com\",\n  \"password\": \"password123\",\n  \"userData\": {\n    \"full_name\": \"John Doe\",\n    \"role\": \"candidate\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            }
          }
        },
        {
          "name": "Sign In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.session) {",
                  "        pm.collectionVariables.set('token', response.data.session.access_token);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"candidate@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signin",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signin"]
            }
          }
        },
        {
          "name": "Sign Out",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/signout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signout"]
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Get All Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Search Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs?search=developer&location=Hanoi",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs"],
              "query": [
                {
                  "key": "search",
                  "value": "developer"
                },
                {
                  "key": "location",
                  "value": "Hanoi"
                }
              ]
            }
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "job-uuid-here"
                }
              ]
            }
          }
        },
        {
          "name": "Create Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recruiter_id\": \"user-uuid-here\",\n  \"title\": \"Senior Full Stack Developer\",\n  \"description\": \"We are looking for an experienced Full Stack Developer...\",\n  \"requirements\": \"5+ years of experience with React and Node.js\",\n  \"location\": \"Ho Chi Minh City\",\n  \"job_type\": \"full-time\",\n  \"salary_min\": 30000000,\n  \"salary_max\": 50000000,\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/jobs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs"]
            }
          }
        },
        {
          "name": "Update Job",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Senior Full Stack Developer (Updated)\",\n  \"salary_max\": 60000000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/jobs/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "job-uuid-here"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Job",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "job-uuid-here"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Get All Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/applications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications"]
            }
          }
        },
        {
          "name": "Get Application by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/applications/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "application-uuid-here"
                }
              ]
            }
          }
        },
        {
          "name": "Submit Application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"job_id\": \"job-uuid-here\",\n  \"user_id\": \"user-uuid-here\",\n  \"resume_url\": \"https://example.com/resume.pdf\",\n  \"cover_letter\": \"I am very interested in this position...\",\n  \"answers\": {\n    \"question1\": \"Answer 1\",\n    \"question2\": \"Answer 2\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/applications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications"]
            }
          }
        },
        {
          "name": "Update Application Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"interview\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/applications/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", ":id", "status"],
              "variable": [
                {
                  "key": "id",
                  "value": "application-uuid-here"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Profiles",
      "item": [
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/profiles/:userId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", ":userId"],
              "variable": [
                {
                  "key": "userId",
                  "value": "user-uuid-here"
                }
              ]
            }
          }
        },
        {
          "name": "Update User Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Doe Updated\",\n  \"phone\": \"+84123456789\",\n  \"location\": \"Ho Chi Minh City\",\n  \"bio\": \"Experienced software developer...\",\n  \"skills\": [\"JavaScript\", \"React\", \"Node.js\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/profiles/:userId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", ":userId"],
              "variable": [
                {
                  "key": "userId",
                  "value": "user-uuid-here"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Get Conversations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/messages/conversations?userId=user-uuid-here",
              "host": ["{{baseUrl}}"],
              "path": ["api", "messages", "conversations"],
              "query": [
                {
                  "key": "userId",
                  "value": "user-uuid-here"
                }
              ]
            }
          }
        },
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/messages/:conversationId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "messages", ":conversationId"],
              "variable": [
                {
                  "key": "conversationId",
                  "value": "conversation-uuid-here"
                }
              ]
            }
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conversation_id\": \"conversation-uuid-here\",\n  \"sender_id\": \"user-uuid-here\",\n  \"content\": \"Hello, I have a question about the job...\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/messages",
              "host": ["{{baseUrl}}"],
              "path": ["api", "messages"]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Get Recruiter Analytics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/analytics/recruiter/:recruiterId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "recruiter", ":recruiterId"],
              "variable": [
                {
                  "key": "recruiterId",
                  "value": "recruiter-uuid-here"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
